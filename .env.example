# Telegram bot token from @BotFather
BOT_TOKEN=your-bot-token-here

# Webhook URL (leave empty for polling mode in dev)
WEBHOOK_URL=

# Webhook secret — Telegram sends this in X-Telegram-Bot-Api-Secret-Token header.
# Rejects requests without it. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=

# Comma-separated list of allowed Telegram user IDs (empty = allow all)
ALLOWED_USER_IDS=[]

# Anthropic authentication
# Priority: OAuth via ~/.claude/.credentials.json (Max/Pro subscription) > API key
# If you have Claude Code logged in, leave ANTHROPIC_API_KEY empty — it will use OAuth automatically.
# Only set this as a fallback or for production without OAuth.
ANTHROPIC_API_KEY=

# Brain model (claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5)
BRAIN_MODEL=claude-sonnet-4-6
BRAIN_MAX_TOKENS=8192

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/taskforce
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/taskforce

# Redis
REDIS_URL=redis://localhost:6379/0

# App
DEBUG=true
LOG_LEVEL=INFO
